%% 40---------------------
% --- NUEVO PLOT DE BATCH EFFECT ---
cur_fig = '40_pca_batch_effect';
out_file = fullfile(fig_path,[cur_fig,'.pdf']);
warning off all;
figure('visible','off');
setup_publication_figure();
% Asegura 'pheno_table' en este ámbito (evita el error de variable no compartida)

% Asegura 'pheno_table' y acceso robusto a la columna Batch (insensible a mayúsculas)
pheno_table = readtable(fullfile(layout_path,'phenodata_arabidopsis_project.tsv'), ...
                        'FileType','text','Delimiter','\t');
varnames = pheno_table.Properties.VariableNames;
ixBatch  = find(strcmpi(varnames,'Batch'),1);
ixCode   = find(strcmpi(varnames,'Code'),1);
ixSName  = find(strcmpi(varnames,'Sample_Name'),1);

sample_batches = cell(n_samples,1);

% Si no hay columna Batch, márcalo como 'Unknown' y sigue
if isempty(ixBatch)
    [sample_batches{:}] = deal('Unknown');
else
    BATCH = pheno_table.(varnames{ixBatch});
    if isstring(BATCH); BATCH = cellstr(BATCH); end  % a celdas de char

    for i = 1:n_samples
        % 1) intento exacto por Code == raw_names{i}
        match_idx = [];
        if ~isempty(ixCode)
            CODE = pheno_table.(varnames{ixCode});
            if isstring(CODE); CODE = cellstr(CODE); end
            match_idx = find(strcmp(CODE, raw_names{i}), 1);
        end

        % 2) intento por Code == clean_names (cambiando '-' por '_')
        if isempty(match_idx) && ~isempty(ixCode)
            alt = strrep(clean_names{i},'-','_');
            match_idx = find(strcmp(CODE, alt), 1);
        end

        % 3) intento por subcadena en Sample_Name que contenga raw_names{i}
        if isempty(match_idx) && ~isempty(ixSName)
            SNAME = pheno_table.(varnames{ixSName});
            if isstring(SNAME); SNAME = cellstr(SNAME); end
            match_idx = find(contains(SNAME, raw_names{i}), 1);
            if isempty(match_idx)  % subcadena con clean_names también
                match_idx = find(contains(SNAME, strrep(clean_names{i},'-','_')), 1);
            end
        end

        % Asignación segura
        if isempty(match_idx) || isempty(BATCH{match_idx})
            sample_batches{i} = 'Unknown';
        else
            sample_batches{i} = BATCH{match_idx};
        end
    end
end

% Usar los mismos datos de PCA que la Figura 03

