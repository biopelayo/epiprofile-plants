 function OutputFigures(layout_path,raw_names)
%% OutputFigures — QC and summary figures from EpiProfile MAT outputs (H3/H4 variant)
%
%  VERSION 3: Now includes Phenodata integration for sample grouping (e.g., YNG vs SEN)
% 
% OUTPUTS (FILES WRITTEN)
%    ... (Todas las 39 Figuras) ...
%    <layout_path>/heatmap_clustering/Figure Legends.txt
% -------------------------------------------------------------------------
%% OutputFigures — QC and summary figures from EpiProfile MAT outputs (H3/H4 variant)
%
%  VERSION 3: Now includes Phenodata integration for sample grouping (e.g., YNG vs SEN)
% 
% OUTPUTS (FILES WRITTEN)
%    ... (Todas las 39 Figuras) ...
%    <layout_path>/heatmap_clustering/Figure Legends.txt
% -------------------------------------------------------------------------
%% 0. Carga de Fenotipos y Preparación de Grupos
pheno_path = fullfile(layout_path, 'phenodata_arabidopsis_project.tsv');
if ~exist(pheno_path, 'file')
    error('Phenodata file not found: %s. Place "phenodata_arabidopsis_project.tsv" in your layout_path.', pheno_path);
end
% --- Bloque de lectura de tabla corregido para ser tolerante a nombres y delimitadores ---
pheno_table = readtable(pheno_path, 'FileType','text','Delimiter','\t');

% Normalizar Code y Sample_Name a cellstr sin espacios
codes_raw = pheno_table.Code;
names_raw = pheno_table.Sample_Name;

if isstring(codes_raw); codes_raw = cellstr(codes_raw); end
if isstring(names_raw); names_raw = cellstr(names_raw); end

codes_clean = cellfun(@strtrim, codes_raw,  'UniformOutput', false);
names_clean = cellfun(@strtrim, names_raw,  'UniformOutput', false);

n_samples  = numel(raw_names);
sample_groups = cell(n_samples, 1);
clean_names   = cell(1, n_samples);
original_raw_names_for_legend = cell(1, n_samples);

for i = 1:n_samples
    current_raw_name = strtrim(raw_names{i});  % por si viniera con espacios
    match_idx = [];

    % 1) match exacto en Code
    match_idx = find(strcmp(codes_clean, current_raw_name), 1);

    % 2) si falla, subcadena en Sample_Name
    if isempty(match_idx)
        match_idx = find(contains(names_clean, current_raw_name), 1);
    end

    if isempty(match_idx)
        error('Raw name "%s" not found as exact match in "Code" or as substring in "Sample_Name" of phenodata_arabidopsis_project.tsv. PLEASE CHECK YOUR PHENODATA FILE FOR MISSING ROWS OR EXTRA SPACES.', ...
              current_raw_name);
    end

    temp_name             = codes_clean{match_idx};
    sample_groups{i}      = pheno_table.Sample_Group{match_idx};
    clean_names{i}        = strrep(temp_name, '_', '-');
    original_raw_names_for_legend{i} = sprintf('%d, %s', i, clean_names{i});
end

[unique_groups, ~, group_idx_num] = unique(sample_groups, 'stable');
num_groups = length(unique_groups);
disp(raw_names(:))
disp(pheno_table)

% --- ARREGLO DE LEYENDA (h_leg) ---
h_leg = [];
% Vector para rastrear si ya hemos dibujado la primera línea de cada grupo
grupo_dibujado = false(1, num_groups);
% ---------------------------------

% Paleta fija y reutilizable para todos los plots
group_colors = palette_groups(num_groups);
% Encontrar límites de grupo para líneas verticales
group_boundaries = find(diff(group_idx_num)) + 0.5;

%% 1. Carga de datos y Dibujo de Figuras (ESTA ES LA PARTE QUE DEBES REVISAR AHORA)
% ... (Tu código para cargar los archivos .mat y dibujar las figuras comienza aquí)


%% 1. Carga de Datos y Procesamiento
% (Código de carga de datos sin cambios)
i = 1;
cur_rawname = raw_names{i};
if i<10
    prefix = ['0',num2str(i)];
else
    prefix = num2str(i);
end;
cur_outpath = fullfile(layout_path,[prefix,'_',cur_rawname],'detail');
npeps = 0;
out_file1 = fullfile(cur_outpath,'*.mat');
matfiles = dir(out_file1);
for j=1:length(matfiles)
    matfile1 = fullfile(cur_outpath,matfiles(j).name);
    load(matfile1, 'His'); 
    npeps = npeps + size(His.pep_mz,1);
end;
c_npeps = zeros([2,1]);
out_file1 = fullfile(cur_outpath,'*.mat');
matfiles = dir(out_file1);
for j=1:length(matfiles)
    matfile1 = fullfile(cur_outpath,matfiles(j).name);
    load(matfile1, 'His');
    cnp = size(His.pep_mz,1);
    pepname = matfiles(j).name(1:end-4);
    if 1==strcmp(pepname(1:2),'HH')
        pepname = pepname(2:end);
    end;
    if 1==strcmp(pepname(1:2),'H3')
        c_npeps(1) = c_npeps(1) + cnp;
    elseif 1==strcmp(pepname(1:2),'H4')
        c_npeps(2) = c_npeps(2) + cnp;
    end;
end;
m = 0;
peptides = repmat({''},[npeps,1]);
out_file1 = fullfile(cur_outpath,'*.mat');
matfiles = dir(out_file1);
for j=1:length(matfiles)
    matfile1 = fullfile(cur_outpath,matfiles(j).name);
    load(matfile1, 'His'); 
    pepname = matfiles(j).name(1:end-4);
    if 1==strcmp(pepname(1:2),'HH')
        pepname = pepname(2:end);
    end;
    p = strfind(pepname,'_');
    version = pepname(p(1)+1:p(2)-1);
    bvar = 0;
    if length(version)>=4
        if 1==strcmp(pepname(1:7),'H3_04v3')
            version = version(4);
        else
            version = version(4:end);
        end;
        histone_pos = [pepname(1:p(1)-1),version,'_',pepname(p(2)+1:p(3)-1),'_',pepname(p(3)+1:end)];
    elseif length(version)==3 && version(3)=='v'
        bvar = 1;
        histone_pos = ['_',pepname(p(2)+1:p(3)-1),'_',pepname(p(3)+1:end)];
    else
        histone_pos = [pepname(1:p(1)-1),'_',pepname(p(2)+1:p(3)-1),'_',pepname(p(3)+1:end)];
    end;
    nlen = size(His.pep_mz,1);
    for ino = m+1:m+nlen
        if 1==bvar
            x = strfind(His.mod_short{ino-m},'.');
            if 1==strcmp(pepname(1:3),'H2B')
                peptides{ino,1} = ['H2B',His.mod_short{ino-m}(1:x(1)-1),histone_pos];
            else
                peptides{ino,1} = [His.mod_short{ino-m}(1:x(1)-1),histone_pos];
            end;
        else
            peptides{ino,1} = [histone_pos,' ',His.mod_short{ino-m}];
        end;
    end;
    m = m+nlen;
end;
info = zeros([npeps,length(raw_names)*3]);
for i=1:length(raw_names)
    cur_rawname = raw_names{i};
    if i<10
        prefix = ['0',num2str(i)];
    else
        prefix = num2str(i);
    end;
    cur_outpath = fullfile(layout_path,[prefix,'_',cur_rawname],'detail');
    m = 0;
    for j = 1:length(matfiles)
        matfile1 = fullfile(cur_outpath,matfiles(j).name);
        load(matfile1, 'auc', 'His');
        nlen = size(His.pep_mz,1);
        info(m+1:m+nlen,(i-1)*3+1:(i-1)*3+3) = auc;
        m = m+nlen;
    end;
end;
info0 = zeros([npeps,length(raw_names)*3]);
for jno=1:length(raw_names)
    info0(:,jno) = info(:,(jno-1)*3+1);
end;
for jno=1:length(raw_names)
    info0(:,length(raw_names)+jno) = info(:,(jno-1)*3+2);
end;
for jno=1:length(raw_names)
    info0(:,2*length(raw_names)+jno) = info(:,(jno-1)*3+3);
end;
info = info0;
info_auc = info(1:npeps,length(raw_names)+1:2*length(raw_names));
info_ratio = info(1:npeps,2*length(raw_names)+1:3*length(raw_names));
info_ratio_log = log2((info_ratio+1e-10)*2^5);
zscore_ratio = zscore(info_ratio_log,[],2);

%% Preparación de Figuras
fig_path = fullfile(layout_path,'heatmap_clustering');
if 0==exist(fig_path,'dir') && 0==mkdir(fig_path)
    fprintf(1,'Cannot create: %s\n',fig_path);
    return;
end;
ratio_labels = {'0.1%','0.2%','0.4%','0.8%','1.6%','3.125%','6.25%','12.5%','25%','50%','100%'};

%% 01---------------------
cur_fig = '01_bar_peptide_number';
out_file = fullfile(fig_path,[cur_fig,'.pdf']);
warning off all;

figure('visible','off');
setup_publication_figure();
set(gcf,'Units','inches','Position',[0 0 6.8 4.8]);  % un poco más grande

% --- datos ---
pepnos = sum(info_auc > 0, 1)';

% --- barras, coloreadas por grupo ---
hBar = bar(pepnos,'FaceColor','flat');
ax = gca;
ax.Box      = 'off';
ax.FontName = 'Arial';
ax.FontSize = 11;   % ejes un pelín más grandes

% colorear cada barra según Sample_Group
for i = 1:n_samples
    g_idx = group_idx_num(i);              % índice de grupo (YNG/BOT/...)
    hBar.CData(i,:) = group_colors(g_idx,:);
end

% ejes
xlabel('Sample','FontSize',12);
ylabel('Number of quantified peptides','FontSize',12);

% límites y ticks
xlim([0.5 n_samples+0.5]);
ylim([0 max(pepnos)*1.25]);  % más espacio arriba para separar título
set(ax,'XTick',1:n_samples,'XTickLabel',clean_names,'XTickLabelRotation',45);

% --- título grande + subtítulo corto ---
mainTitle = 'Quantified peptide count per sample';
subTitle  = sprintf('Total theoretical peptides: %d', npeps);
title({mainTitle; subTitle}, ...
      'FontSize',14, 'FontWeight','bold');

% --- líneas de grupo (como antes) ---
hold on;
for b = 1:length(group_boundaries)
    line([group_boundaries(b) group_boundaries(b)], ylim, ...
         'Color',[0.6 0.6 0.6], 'LineStyle','--', 'LineWidth',1);
end
hold off;

% --- explicación simple en un lateral (fuera de los ejes) ---
fig = gcf;
annotation(fig,'textbox',[0.13 0.02 0.74 0.05], ...  % [x y w h] en coords normalizadas
    'String','Bars show peptides with Area > 0 in each sample.', ...
    'HorizontalAlignment','center', ...
    'VerticalAlignment','middle', ...
    'FontSize',9, ...
    'EdgeColor','none');

print('-dpdf','-painters','-r600',out_file);
close();

%% 02---------------------
cur_fig = '02_boxplot_peptide_intensity';
out_file = fullfile(fig_path,[cur_fig,'.pdf']);
warning off all;

figure('visible','off');
setup_publication_figure();
set(gcf,'Units','inches','Position',[0 0 6.8 4.8]);  % igual tamaño que la 01

% --- datos (log10, limpiando infinitos) ---
data_log10 = log10(info_auc);
data_log10(~isfinite(data_log10)) = NaN;

% matriz de colores por muestra (según Sample_Group)
colmat = zeros(n_samples,3);
for i = 1:n_samples
    colmat(i,:) = group_colors(group_idx_num(i),:);
end

% --- boxplot básico, coloreado por grupo ---
boxplot(data_log10, ...
        'Labels', clean_names, ...
        'PlotStyle','compact', ...
        'Colors', colmat, ...
        'Symbol','+');

ax = gca;
ax.Box      = 'off';
ax.FontName = 'Arial';
ax.FontSize = 11;

% título + subtítulo
mainTitle = 'Distribution of peptide intensity';
subTitle  = 'Log_{10} peak area per sample';
title({mainTitle; subTitle}, ...
      'FontSize',14,'FontWeight','bold');

% ejes
xlabel('Sample','FontSize',12);
ylabel('Peptide intensity (log_{10} area)','FontSize',12);
set(ax,'XTickLabelRotation',45);

% límites y margen vertical
yl = ylim;
ylim([yl(1) yl(2)+0.10*diff(yl)]);  % un poco de aire arriba

% --- líneas de grupo en gris claro ---
hold on;
for b = 1:length(group_boundaries)
    line([group_boundaries(b) group_boundaries(b)], ylim, ...
         'Color',[0.6 0.6 0.6], 'LineStyle','--', 'LineWidth',1);
end
hold off;

% --- explicación simple abajo, fuera del eje ---
fig = gcf;
annotation(fig,'textbox',[0.13 0.02 0.74 0.05], ...
    'String','Boxplots of log_{10} peptide areas. Used to check sample loading and MS sensitivity.', ...
    'HorizontalAlignment','center', ...
    'VerticalAlignment','middle', ...
    'FontSize',9, ...
    'EdgeColor','none');

print('-dpdf','-painters','-r600',out_file);
close();

%% 03---------------------
% --- PCA con grupos (versión publicación) ---
cur_fig = '03_pca';
out_file = fullfile(fig_path,[cur_fig,'.pdf']);
warning off all;

figure('visible','off');
setup_publication_figure();
set(gcf,'Units','inches','Position',[0 0 5.5 5.0]);   % más cuadrada

% Datos: PCA sobre matriz de ratios z-score
cur_ratio = zscore_ratio;
[~, score, latent] = pca(cur_ratio');

% Scatter por grupos con puntos grandes y rellenos
ax = gca;
[ax, Scat] = scatter_grouped(score(:,1), score(:,2), ...
                             sample_groups, group_colors, 55);  % tamaño punto

ax.FontName = 'Arial';
ax.FontSize = 11;
grid(ax,'on');
box(ax,'on');

% % varianza explicada
varPC1 = latent(1)/sum(latent)*100;
varPC2 = latent(2)/sum(latent)*100;

% Títulos y labels tipo publicación
title({'PCA of samples', ...
       'All peptides (log_{2}-ratio matrix)'}, ...
      'FontSize',14,'FontWeight','bold');

xlabel(sprintf('PC1 (%.1f%%%% variance)', varPC1), 'FontSize',12);
ylabel(sprintf('PC2 (%.1f%%%% variance)', varPC2), 'FontSize',12);

% Ajustar márgenes alrededor de los puntos
pad_axes(ax,0.06);

% Leyenda de grupos, horizontal abajo
leg = legend(Scat.handles, Scat.names, ...
             'Location','SouthOutside', ...
             'Orientation','horizontal', ...
             'Box','off');
leg.FontSize = 10;

% Explicación simple abajo, fuera del eje
fig = gcf;
annotation(fig,'textbox',[0.12 0.01 0.76 0.05], ...
    'String','PCA on Z-scored log_{2} ratios. Samples coloured by Sample_Group; distances reflect similarity.', ...
    'HorizontalAlignment','center', ...
    'VerticalAlignment','middle', ...
    'FontSize',9, ...
    'EdgeColor','none');

print('-dpdf','-painters','-r600',out_file);
close();


%% --------------------------------------------------------------------------------
% --- BLOQUE DE PLOTS AMPLIADO (Figuras 14 a 39) ---
% --------------------------------------------------------------------------------
index = [1;cumsum(c_npeps)+1];
data_H3 = info_ratio_log(index(1):index(2)-1,:);
data_H4 = info_ratio_log(index(2):index(3)-1,:);
full_data = [data_H3; data_H4];
sample_indices = repmat(1:n_samples, size(full_data, 1), 1);
full_data_flat = full_data(:);
sample_indices_flat = sample_indices(:);

%% 14---------------------
% --- Violin / boxplot H3 vs H4 por muestra (versión publicación, con color por histona) ---
cur_fig  = '14_violinplot_ratio_H3_H4';
out_file = fullfile(fig_path,[cur_fig,'.pdf']);
warning off all;

figure('visible','off');
setup_publication_figure();
set(gcf,'Units','inches','Position',[0 0 10 4.8]);   % ancho para muchas muestras

ax = gca;
ax.FontName = 'Arial';
ax.FontSize = 11;
ax.Box      = 'on';
hold(ax,'on');

% --- colores para cada histona (H3 / H4) usando tu paleta ---
hist_cols = palette_groups(2);   % [color_H3; color_H4]
col_H3    = hist_cols(1,:);
col_H4    = hist_cols(2,:);

if exist('violin','file')
    % --- montaje de factores: muestra (1..n) y clase (H3/H4) ---
    group_var_class = [repmat({'H3'}, size(data_H3, 1), 1); ...
                       repmat({'H4'}, size(data_H4, 1), 1)];
    group_var_class_flat = repmat(group_var_class, n_samples, 1);

    % Violin plot: dos violines por muestra (H3 / H4)
    hv = violin(full_data_flat, ...
                'groups', {sample_indices_flat, group_var_class_flat}, ...
                'histType','area', ...
                'medc','k', ...
                'width',0.8, ...
                'bandwidth',0.5, ...
                'plotLine',true);

    % Recolorear violines: alternando H3 (izq) / H4 (der) por muestra
    % Buscamos los patches, los ordenamos por posición X media y alternamos colores
    patches = findobj(ax,'Type','patch');
    nP      = numel(patches);
    xmean   = zeros(nP,1);
    for k = 1:nP
        xv       = get(patches(k),'XData');
        xmean(k) = mean(xv(:));
    end
    [~,ord] = sort(xmean);           % de izquierda a derecha
    patches = patches(ord);

    for k = 1:nP
        if mod(k,2)==1
            set(patches(k), 'FaceColor', col_H3, 'EdgeColor',[0.2 0.2 0.2]);
        else
            set(patches(k), 'FaceColor', col_H4, 'EdgeColor',[0.2 0.2 0.2]);
        end
    end

    % Poner el tick entre H3/H4 de cada muestra
    set(ax,'XTick', 1.5:2:(2*n_samples-0.5), ...
           'XTickLabel', clean_names, ...
           'XTickLabelRotation',45);

else
    % --- fallback: boxplots compactos si no existe violin.m ---
    fprintf(1,'WARNING: ''violin'' function not found. Generating Boxplots for Figure 14.\n');

    G                = cell(length(full_data_flat), 1);
    group_order_list = cell(1, 2*n_samples);
    N_peps_H3        = size(data_H3, 1);
    N_peps_H4        = size(data_H4, 1);
    offset           = N_peps_H3 * n_samples;

    for i = 1:n_samples
        group_h3 = ['H3_S', num2str(i)];
        group_h4 = ['H4_S', num2str(i)];
        group_order_list{2*i-1} = group_h3;
        group_order_list{2*i}   = group_h4;

        idx_H3_start = (i-1) * N_peps_H3 + 1;
        idx_H3_end   = i * N_peps_H3;
        G(idx_H3_start:idx_H3_end) = {group_h3};

        idx_H4_start = offset + (i-1) * N_peps_H4 + 1;
        idx_H4_end   = offset + i * N_peps_H4;
        G[idx_H4_start:idx_H4_end) = {group_h4};
    end

    valid_indices = ~isnan(full_data_flat);
    boxplot(full_data_flat(valid_indices), G(valid_indices), ...
            'plotstyle','compact', ...
            'GroupOrder', group_order_list);

    % Etiquetas: nombre de muestra + clase
    x_tick_labels = cell(1, 2*n_samples);
    for i = 1:n_samples
        x_tick_labels{2*i-1} = [clean_names{i}, ' (H3)'];
        x_tick_labels{2*i}   = [clean_names{i}, ' (H4)'];
    end
    set(ax,'XTickLabel',x_tick_labels,'XTickLabelRotation',45);

    % Colorear las cajas: odd = H3, even = H4
    boxes = findobj(ax,'Tag','Box');
    nB    = numel(boxes);
    xmean = zeros(nB,1);
    for k = 1:nB
        xv       = get(boxes(k),'XData');
        xmean(k) = mean(xv(:));
    end
    [~,ord] = sort(xmean);   % de izquierda a derecha
    boxes   = boxes(ord);

    for k = 1:nB
        if mod(k,2)==1
            set(boxes(k),'Color',col_H3,'LineWidth',1.2);
        else
            set(boxes(k),'Color',col_H4,'LineWidth',1.2);
        end
    end
end

% Título y ejes “journal-like”
title({'Log_{2} ratio distribution per sample', ...
       'H3 vs H4 histone classes'}, ...
      'FontSize',14,'FontWeight','bold');

xlabel('Sample','FontSize',12);
ylabel('Relative abundance (log_{2} ratio)','FontSize',12);

% Añadir líneas de grupo (cada grupo ocupa 2 posiciones: H3 y H4)
yl = ylim;
for b = 1:length(group_boundaries)
    xg = group_boundaries(b)*2;
    line([xg xg], yl, 'Color',[0.5 0.5 0.5], 'LineStyle','--', 'LineWidth',1);
end
ylim(yl);   % mantener límites

% Algo de aire alrededor
pad_axes(ax,0.04);

% Leyenda H3/H4 usando dummy handles coloreados
hH3 = plot(ax, nan, nan, 's', ...
    'MarkerFaceColor', col_H3, 'MarkerEdgeColor','k', ...
    'LineWidth',1.0, 'DisplayName','H3');
hH4 = plot(ax, nan, nan, 's', ...
    'MarkerFaceColor', col_H4, 'MarkerEdgeColor','k', ...
    'LineWidth',1.0, 'DisplayName','H4');

legend([hH3 hH4], {'H3','H4'}, 'Location','NorthEastOutside','Box','off');

% Explicación sencilla fuera del eje (abajo)
fig = gcf;
annotation(fig,'textbox',[0.12 0.01 0.76 0.05], ...
    'String','Distributions of log_{2} peptide ratios for H3 and H4 in each sample. Two entries per sample: H3 (left) and H4 (right).', ...
    'HorizontalAlignment','center', ...
    'VerticalAlignment','middle', ...
    'FontSize',9, ...
    'EdgeColor','none');

print('-dpdf','-painters','-r600',out_file);
close();

%% 15---------------------
% QC summary table per sample (counts, missingness, medians)
cur_fig  = '15_scatter_Area_vs_Ratio';   % dejamos el nombre de fichero igual
out_file = fullfile(fig_path,[cur_fig,'.pdf']);
warning off all;

figure('visible','off');
setup_publication_figure();
set(gcf,'Units','inches','Position',[0 0 8.5 5.5]);  % formato “tabla”

ax = gca;
ax.Visible   = 'off';         % sin ejes
ax.Position  = [0.05 0.05 0.9 0.85];

% --- métricas por muestra ---
total_peps       = size(info_auc,1);
pep_count        = sum(info_auc>0,1);           % nº péptidos cuantificados
missing_count    = sum(info_auc==0,1);          % nº péptidos missing
missing_pct      = 100*missing_count/total_peps;

log10_area       = log10(info_auc);
log10_area(info_auc<=0) = NaN;
median_log10     = median(log10_area, 1, 'omitnan');

median_log2ratio = median(info_ratio_log, 1, 'omitnan');

% --- título ---
title({'QC summary by sample', ...
       'Peptide counts, missing values and central tendencies'}, ...
       'FontSize',14,'FontWeight','bold');

% --- cabecera y filas (texto monoespaciado) ---
fontName  = 'Consolas';
base_y    = 0.90;
dy        = 0.045;

header = sprintf('%-10s  %-10s  %8s  %10s  %14s  %14s', ...
                 'Sample','Group','n_peps','Missing_%', ...
                 'median log_{10}A','median log_{2}ratio');
text(0.02, base_y, header, 'FontName',fontName, ...
     'FontSize',10, 'FontWeight','bold', 'Interpreter','none');

for i = 1:n_samples
    this_name  = clean_names{i};
    if length(this_name) > 10
        this_name = this_name(1:10);
    end
    this_group = sample_groups{i};
    if length(this_group) > 10
        this_group = this_group(1:10);
    end

    row_str = sprintf('%-10s  %-10s  %8d  %10.1f  %14.2f  %14.2f', ...
                      this_name, ...
                      this_group, ...
                      pep_count(i), ...
                      missing_pct(i), ...
                      median_log10(i), ...
                      median_log2ratio(i));

    text(0.02, base_y - i*dy, row_str, ...
         'FontName',fontName, 'FontSize',9, ...
         'Interpreter','none');
end

% pequeña nota al pie
annotation(gcf,'textbox',[0.02 0.01 0.96 0.04], ...
    'String','Summary statistics computed over all quantified peptides (rows in the AUC / ratio matrices).', ...
    'HorizontalAlignment','center', ...
    'VerticalAlignment','middle', ...
    'FontSize',9, 'EdgeColor','none');

print('-dpdf','-painters','-r600',out_file);
close();



%% 16---------------------
% --- HEATMAP DE MISSING VALUES, SEPARANDO H3/H4 Y RESUMIENDO PÉPTIDOS ---
cur_fig = '16_heatmap_missing_values';
out_file = fullfile(fig_path,[cur_fig,'.pdf']);
warning off all;

figure('visible','off');
setup_publication_figure();
set(gcf,'Units','inches','Position',[0 0 6 8]);   % algo más ancho/alto

% matriz binaria de detección
detection_matrix = double(info_auc > 0);    % [n_peps x n_samples]
[npeps, ~]       = size(detection_matrix);

% límites H3 / H4 (ya vienen de c_npeps)
index    = [1; cumsum(c_npeps)+1];          % index(1)=1, index(2)=H3+1, index(3)=H3+H4+1
ix_H3    = index(1):index(2)-1;
ix_H4    = index(2):index(3)-1;

% heatmap
imagesc(detection_matrix);

% colormap: gris secuencial (missing = blanco, detectado = gris oscuro)
if exist('sequential_grey','file')
    colormap(sequential_grey(2));
else
    colormap([1 1 1; 0.3 0.3 0.3]);
end

ax = gca;
ax.FontName = 'Arial';
ax.FontSize = 9;

% título y subtítulo
mainTitle = 'Peptide detection matrix (missing values)';
subTitle  = sprintf('Rows = individual histone peptides (H3/H4); columns = %d samples', n_samples);
title({mainTitle; subTitle}, 'FontSize',12,'FontWeight','bold');

% ejes
xlabel('Sample','FontSize',11);
ylabel('Peptide class','FontSize',11);

% ticks de X: muestras
set(ax, 'XTick', 1:n_samples, ...
        'XTickLabel', clean_names, ...
        'XTickLabelRotation', 45);

% ticks de Y: sólo centro H3 y centro H4 (para que se lean bien)
mid_H3 = (ix_H3(1) + ix_H3(end))/2;
mid_H4 = (ix_H4(1) + ix_H4(end))/2;
set(ax, 'YTick', [mid_H3 mid_H4], ...
        'YTickLabel', {sprintf('H3 peptides (n = %d)', numel(ix_H3)), ...
                       sprintf('H4 peptides (n = %d)', numel(ix_H4))});

% línea horizontal separando H3 y H4
hold on;
yline(ix_H4(1)-0.5, 'k-', 'LineWidth', 1.2);

% líneas verticales de grupo (YNG / BOT / FLOR / SEN, etc.)
for b = 1:length(group_boundaries)
    xline(group_boundaries(b), 'Color',[0.5 0.5 0.5], 'LineStyle','--', 'LineWidth',1);
end
hold off;

% colorbar binario
cb = colorbar('Ticks', [0.25, 0.75], ...
              'TickLabels', {'Missing (Area = 0)', 'Detected (Area > 0)'}, ...
              'Position', [0.92 0.2 0.02 0.65]);
cb.Label.String = 'Detection status';

% ---------------------------
% RESUMEN DE PÉPTIDOS: TOP MISSING
% ---------------------------
missing_pct = 100 * sum(detection_matrix == 0, 2) / n_samples;
[sorted_missing, idx_missing] = sort(missing_pct, 'descend');

n_show = min(8, npeps);  % máximo 8 péptidos para que se lean
lines = cell(n_show+1,1);
lines{1} = 'Top peptides by missing percentage:';

for k = 1:n_show
    pep_name = peptides{idx_missing(k)};
    % recortar nombre si es larguísimo para que quepa
    if numel(pep_name) > 45
        pep_name = [pep_name(1:42) '...'];
    end
    lines{k+1} = sprintf('%2d) %s  (%.1f%% missing)', ...
                         k, pep_name, sorted_missing(k));
end

annotation(gcf,'textbox',[0.03 0.02 0.94 0.16], ...
    'String', lines, ...
    'FontSize',8, ...
    'FontName','Consolas', ...
    'Interpreter','none', ...
    'HorizontalAlignment','left', ...
    'VerticalAlignment','top', ...
    'EdgeColor','none');

print('-dpdf','-painters','-r600',out_file);
close();


%% 17---------------------
% --- LOLLIPOP PLOT DE % DE PÉPTIDOS CON RATIO BAJO (<1%) ---
cur_fig = '17_barplot_low_ratio_percentage';   % mantengo el nombre para no romper nada aguas abajo
out_file = fullfile(fig_path,[cur_fig,'.pdf']);
warning off all;

figure('visible','off');
setup_publication_figure();
set(gcf,'Units','inches','Position',[0 0 7.0 5.0]);  % un poco más grande

ax = gca;
ax.FontName = 'Arial';
ax.FontSize = 10;

% --- cálculo del % de péptidos con ratio < 1%% ---
title_str = 'Low-abundance peptide ratios per sample';
subtitle_str = 'Share of peptides with estimated ratio < 1%';

threshold = log2((0.01 + 1e-10)*2^5); 
low_ratio_count = sum(info_ratio_log < threshold, 1);
low_ratio_percentage = (low_ratio_count ./ size(info_ratio_log, 1)) * 100;

% --- eje Y = muestras, eje X = porcentaje ---
y_pos = 1:n_samples;

hold on;

% lollipop por muestra, coloreado por Sample_Group
for i = 1:n_samples
    this_color = group_colors(group_idx_num(i), :);

    % “palito”
    plot([0 low_ratio_percentage(i)], [y_pos(i) y_pos(i)], '-', ...
        'Color', this_color, 'LineWidth', 1.5);

    % “chupa-chups” (punto final)
    plot(low_ratio_percentage(i), y_pos(i), 'o', ...
        'MarkerFaceColor', this_color, ...
        'MarkerEdgeColor', 'k', ...
        'MarkerSize', 5);
end

% límites y ejes
xmax = max(low_ratio_percentage)*1.15;
if xmax < 5
    xmax = 5;
end
xlim([0 xmax]);
ylim([0.5 n_samples+0.5]);

set(ax, 'YTick', y_pos, ...
        'YTickLabel', clean_names, ...
        'YTickLabelRotation', 0);

xlabel('% peptides with ratio < 1%', 'FontSize', 11);
ylabel('Sample', 'FontSize', 11);

% invertimos el eje Y para que la primera muestra quede arriba (opcional)
set(ax, 'YDir', 'reverse');

% --- líneas de grupo horizontales (YNG/BOT/FLOR/SEN, etc.) ---
for b = 1:length(group_boundaries)
    yb = group_boundaries(b);
    line([0 xmax], [yb yb], 'Color', [0.7 0.7 0.7], ...
         'LineStyle', '--', 'LineWidth', 1);
end

% --- leyenda por grupo (dummy handles) ---
leg_handles = gobjects(num_groups,1);
for g = 1:num_groups
    leg_handles(g) = plot(nan, nan, '-', ...
        'Color', group_colors(g,:), ...
        'LineWidth', 2, ...
        'DisplayName', unique_groups{g});
end
legend(leg_handles, unique_groups, 'Location', 'SouthEastOutside');

% --- título principal + subtítulo corto ---
title({title_str; subtitle_str}, 'FontSize', 12, 'FontWeight', 'bold');

% --- pequeña nota explicativa en la parte inferior izquierda ---
annotation(gcf,'textbox',[0.05 0.02 0.7 0.12], ...
    'String','Each line-dot shows the percentage of peptides with very low estimated ratio (<1%). Higher values may indicate noisier quantification for that sample.', ...
    'FontSize',8, ...
    'FontName','Arial', ...
    'HorizontalAlignment','left', ...
    'VerticalAlignment','top', ...
    'EdgeColor','none');

box on;
grid on;

print('-dpdf','-painters','-r600',out_file);
close();

