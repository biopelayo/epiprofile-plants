function setup_publication_figure()
    set(gcf,'Color','w'); 
    set(gcf,'PaperPositionMode','auto'); 
    set(gcf,'Units','inches','Position',[0 0 6 4]); 
    set(gca,'FontSize',10,'FontName','Arial'); 
end
% -------------------------------------------------------------------------
function setup_wide_figure()
    set(gcf,'Color','w');
    set(gcf,'PaperPositionMode','auto');
    set(gcf,'Units','inches','Position',[0 0 10 4]); 
    set(gca,'FontSize',10,'FontName','Arial');
end
