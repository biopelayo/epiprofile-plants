xlabel('1st Principal Component','FontSize',10);
ylabel('2nd Principal Component','FontSize',10);
grid on;
box on;
legend('Location', 'NorthEastOutside');
h = text(min(xlim), min(ylim)*0.9, ...
    'QC Plot: PCA colored by processing Batch. Ideal clustering is by Sample_Group (Fig 03), not by Batch.', ...
    'FontSize',9, 'VerticalAlignment','top');
print('-dpdf','-painters','-r600',out_file);
close();

