function C = palette_groups(k)
% Paleta para grupos (bien contrastada, reproducible)
base = [ ...
    0.121 0.466 0.705;  % azul
    1.000 0.498 0.054;  % naranja
    0.172 0.627 0.172;  % verde
    0.839 0.153 0.157;  % rojo
    0.580 0.404 0.741;  % morado
    0.549 0.337 0.294;  % marrón
    0.890 0.467 0.761;  % rosa
    0.498 0.498 0.498;  % gris
    0.737 0.741 0.133;  % oliva
    0.090 0.745 0.811]; % cian
if k<=size(base,1), C = base(1:k,:); else
    C = interp1(linspace(0,1,size(base,1)), base, linspace(0,1,k), 'pchip');
end
end

function M = diverging_balance(n)
% Divergente suave: azul↔gris↔rojo, ajustado para ratios/correlaciones
x = linspace(-1,1,n)'; 
r = 0.5+0.5*tanh( 2.2*x);
b = 0.5+0.5*tanh(-2.2*x);
g = 0.50 + 0.40*(1-abs(x)).^1.3;
M = [b g r]; M = max(min(M,1),0);
end

function M = sequential_grey(n)
% Secuencial gris para binarios/missing
M = linspace(1,0.3,n)'; M = [M M M];
end

function pad_axes(ax, p)
% Añade margen porcentual a X/Y para “respirar”
if nargin<2, p = 0.05; end
xl = xlim(ax); yl = ylim(ax);
dx = diff(xl); dy = diff(yl);
xlim(ax, [xl(1)-dx*p, xl(2)+dx*p]);
ylim(ax, [yl(1)-dy*p, yl(2)+dy*p]);
end

function [ax,Scat] = scatter_grouped(x,y,groups,cols,sz)
% Scatter por grupos (leyenda estable y limpia)
ax = gca; hold(ax,'on');
[ug,~,gi] = unique(groups,'stable');
m = numel(ug);
H = gobjects(m,1);
for g = 1:m
    idx = gi==g;
    H(g) = scatter(ax, x(idx), y(idx), sz, ...
        'Marker','o','MarkerFaceColor',cols(g,:), ...
        'MarkerEdgeColor','k','MarkerFaceAlpha',0.85,'MarkerEdgeAlpha',0.8);
end
Scat.handles = H; Scat.names = ug;
Scat.leg = H; % para legend(H, ug, ...)
end

function text_repel(ax, x, y, labels, varargin)
% Etiquetas con “repulsión” tipo ggrepel (simple y robusto)
% Uso: text_repel(gca, x, y, clean_names, 'MaxIter',200,'Force',0.05,'Leader',true)
p = inputParser;
addParameter(p,'MaxIter',200);
addParameter(p,'Force',0.05);      % empuje base
addParameter(p,'FontSize',9);
addParameter(p,'Leader',true);     % dibuja líneas guía
parse(p,varargin{:});
opt = p.Results;

% puntos iniciales (desfase mínimo)
nx = x(:); ny = y(:);
tx = nx + 0.005*range(x)*sign(nx-mean(nx));
ty = ny + 0.005*range(y)*sign(ny-mean(y));

% BBoxes aproximados (mismo tamaño, rápido)
fs = opt.FontSize; 
tw = 0.012*range(x) * ones(size(tx));  % ancho aprox.
th = 0.028*range(y) * ones(size(ty));  % alto aprox.

% Iteraciones de relajación
for it = 1:opt.MaxIter
    moved = false;
    for i = 1:numel(tx)
        dx = tx(i)-tx; dy = ty(i)-ty;
        dd = hypot(dx,dy) + eps;
        % colisiones: si superponen cajas
        overlap = (abs(dx) < (tw+tw(i))/2) & (abs(dy) < (th+th(i))/2);
        overlap(i) = false;
        if any(overlap)
            % empuje vectorial lejos de vecinos
            push = sum([(dx(overlap)./dd(overlap)), (dy(overlap)./dd(overlap))],1);
            if any(isfinite(push))
                tx(i) = tx(i) + opt.Force * push(1);
                ty(i) = ty(i) + opt.Force * push(2);
                moved = true;
            end
        end
        % evita solape con el punto original (mínima distancia)
        vx = tx(i)-nx(i); vy = ty(i)-ny(i);
        if hypot(vx,vy) < 0.012*max(range(x),range(y))
            tx(i) = tx(i) + opt.Force * sign(vx + (vx==0)) * 0.5;
            ty(i) = ty(i) + opt.Force * sign(vy + (vy==0)) * 0.5;
            moved = true;
        end
    end
    if ~moved, break; end
end

% Limitar a los límites del eje con un poco de aire
xl = xlim(ax); yl = ylim(ax);
tx = min(max(tx, xl(1)), xl(2));
ty = min(max(ty, yl(1)), yl(2));

% Pintar
hold(ax,'on');
for i = 1:numel(tx)
    if opt.Leader
        plot(ax, [nx(i) tx(i)], [ny(i) ty(i)], '-', 'Color',[0 0 0 0.35], 'LineWidth',0.8);
    end
    text(ax, tx(i), ty(i), labels{i}, ...
        'HorizontalAlignment','center','VerticalAlignment','middle', ...
        'FontSize',opt.FontSize, 'FontName','Arial', 'BackgroundColor',[1 1 1 0.65], ...
        'Margin',2, 'Clipping','on');
end
hold(ax,'off');
end


function write_txt(fig_path, pheno_table)
%% write_txt — emit a plain-text legend file describing the main figures (EXPANDED and in ENGLISH)
txt_file = fullfile(fig_path,'Figure Legends.txt');
fp = fopen(txt_file,'w');
if -1==fp
    fprintf(1,'Cannot open: %s\r\n',txt_file);
    return;
end;

fprintf(fp,'--- Data Overview ---\r\n');
fprintf(fp,'This analysis includes %d samples across %d groups:\r\n', height(pheno_table), length(unique(pheno_table.Sample_Group)));
groups = unique(pheno_table.Sample_Group);
for g = 1:length(groups)
    count = sum(strcmp(pheno_table.Sample_Group, groups{g}));
    fprintf(fp,'  - Group: %s (n=%d)\r\n', groups{g}, count);
end
fprintf(fp,'\r\n');

fprintf(fp,'--- Sample QC Figures ---\r\n');
fprintf(fp,'Figure 01: Bar plot of **Quantified Peptide Count** per sample. Bar height indicates the number of peptides detected with Area > 0. Used as a QC metric; low counts suggest low sensitivity or sample quality issues. Vertical dashed lines separate Sample_Groups.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 02: Box plot displaying the **Log_{10} transformed peptide intensity** (Area) distribution per sample. The median and quartile ranges assess consistency in sample loading and overall MS performance. Vertical dashed lines separate Sample_Groups.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 16: **Binary Heatmap** (Missing Values). Shows peptide detection (1=Detected, 0=Missing) across samples. Visual QC for data completeness and missing data patterns. Vertical dashed lines separate Sample_Groups.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 17: **Bar plot** of the percentage of peptides in each sample with a Log2-Ratio corresponding to an extremely low relative abundance (Ratio < 1%%). High percentage may indicate low signal quality or high noise in quantification. Vertical dashed lines separate Sample_Groups.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 29: **Bar plot of Missing Peptide Count**. Shows the total number of peptides (Area = 0) per sample. Direct QC for sample specific data completeness/dropout rates. Vertical dashed lines separate Sample_Groups.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 24: **Box plot** of "Noise" Ratios (Log2 Ratio where |Ratio| < 1) for each sample. QC for system stability near the baseline signal. Horizontal dashed lines separate Sample_Groups.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'--- Sample Clustering and Correlation (All Peptides) ---\r\n');
fprintf(fp,'Figure 03: **Principal Component Analysis (PCA)** of all samples based on the Z-scored Log2 ratio matrix. Displays the distance/clustering between samples. Points are colored by Sample_Group. Replicates should cluster tightly.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 20: **Heatmap of Spearman Correlation (R-value)** between all sample pairs. Ideal QC: technical replicates should show high correlation (R > 0.9). Columns/Rows are grouped by Sample_Group and separated by dashed lines.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 33: **Hierarchical Clustering Dendrogram**. Shows the clustering of samples based on the Euclidean distance of the Z-scored Log2 ratio matrix (using Ward linkage). Labels are colored by Sample_Group.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 40: **PCA (colored by Batch)**. QC Plot: PCA colored by processing Batch. Ideal clustering is by Sample_Group (Fig 03), not by Batch. Separation by Batch indicates technical artifacts.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'--- Histone Class Specific Analysis (H3 vs H4) ---\r\n');
fprintf(fp,'Figure 11: **Heatmaps of Log2-scaled ratios** for H3 and H4 peptides separately. Shows peptide-level abundance patterns. Columns are grouped by Sample_Group.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 14: **Violin/Box plot** showing the distribution of Log2-transformed ratio values, separated by H3 and H4 histone classes for each sample. \r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 18: **Box plot** comparing the global Log_{10}(Area) distribution between H3 peptides and H4 peptides.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 19: **Scatter plot** comparing the average Log2 Ratio profile of H3 peptides vs. H4 peptides across samples. Points are colored by Sample_Group.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 21: **Bar plot** showing the total theoretical peptide count for the H3 class and the H4 class.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 23: **Line plot** comparing the Median Log2 Ratio profile of H3 and H4 peptides across all samples. Vertical dashed lines separate Sample_Groups.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 25: **PCA** of the samples using **H3 peptide ratios (Z-scored) ONLY**. Points are colored by Sample_Group.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 26: **PCA** of the samples using **H4 peptide ratios (Z-scored) ONLY**. Points are colored by Sample_Group.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 34: **Paired Box Plot: H3 vs. H4 Ratio per Sample**. Displays side-by-side distributions for H3 and H4 within each sample. Vertical dashed lines separate Sample_Groups.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 35: **Density Plot: Overall Log2 Ratio Distribution (H3 vs. H4)**. Compares the global distribution shapes for all H3 and H4 peptides.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'--- H3(73-83) Specific Analysis ---\r\n');
fprintf(fp,'Figure 30: **Log_{2} Ratio Heatmap for H3(73-83) Peptides**. Shows the relative abundance of all modification isoforms quantified on the H3(73-83) region. Columns are grouped.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 31: **Box plot** of the **Ratio Distribution (Log_{2})** for H3(73-83) peptides only. Compares the variability of these specific modifications across samples. Vertical dashed lines separate Sample_Groups.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 32: **Scatter plot** comparing the **Average Log2 Ratio profile of H3(73-83)** peptides versus the **Average Log2 Ratio of ALL H3** peptides. Points are colored by Sample_Group.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 36: **Spearman Correlation Heatmap: H3(73-83) Peptides vs. Other H3 Peptides**. Visualizes pairwise correlation between H3(73-83) isoforms (Y-axis) and all other H3 peptides (X-axis).\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'--- Peptide-Centric Analysis (All Peptides) ---\r\n');
fprintf(fp,'Figure 10: **Heatmaps of single PTM ratios** (Log2-scaled) and Z-scores (if auxiliary file exists). Columns are grouped.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 15: **Scatter plot** comparing Log_{10}(Area) vs. Log_{2}-transformed Ratio (all peptides). A minimal correlation (R near 0) confirms robust normalization.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 22: **Single Box plot** displaying the overall Log2 Ratio distribution across ALL quantified peptides and ALL samples combined.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 27: **Overlay Histogram** showing the frequency distribution of Log2 Ratios for each sample. Lines are colored by Sample_Group.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 28: **Histogram of Peptide Completeness**. Shows the distribution of how many samples each peptide was successfully detected in (Area > 0).\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 37: **Bar plot of Top 25 Most Variable Peptides**. Identifies peptides with the highest standard deviation in Log2 Ratio, which are the main drivers of variance in the dataset.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 38: **Peptide-Peptide Correlation Heatmap**. Shows the Spearman R correlation between all pairs of peptides. Blocks of color indicate modules of co-regulated peptides.\r\n');
fprintf(fp,'\r\n');
fprintf(fp,'Figure 39: **MA Plot (Ratio vs. Intensity)**. Plots average ratio (M) vs. average intensity (A) for each peptide. In a well-normalized dataset, most peptides should center symmetrically around M=0.\r\n');
fclose(fp);
end % write_txt